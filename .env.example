# ─── LLM API Keys (at least one required) ────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ─── Model Selection ─────────────────────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini
FALLBACK_MODEL=groq/llama3-8b-8192

# ─── Application ─────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-use-a-long-random-string

# ─── Database (overridden by docker-compose for container mode) ───────────────
DATABASE_URL=postgresql+asyncpg://multiagent:multiagent@localhost:5432/multiagent_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Evaluation ──────────────────────────────────────────────────────────────
EVAL_THRESHOLD_SCORE=0.7
ENABLE_ADVERSARIAL_TESTING=true

# ─── Frontend (for local dev) ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
