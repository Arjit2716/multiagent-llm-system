# ══════════════════════════════════════════════════════════════════════════════
# .env.example — copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ALL configuration for every service flows through this file.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM API Keys (at least one required) ──────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Model selection ───────────────────────────────────────────────────────────
# Groq free tier (recommended): groq/llama-3.3-70b-versatile
# OpenAI:                        gpt-4o-mini
DEFAULT_MODEL=groq/llama-3.3-70b-versatile
FALLBACK_MODEL=groq/llama-3.1-8b-instant

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=info
SECRET_KEY=change-me-use-a-long-random-string-minimum-32-chars

# ── PostgreSQL (docker-compose injects these into the postgres container) ──────
POSTGRES_USER=multiagent
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=multiagent_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_MAX_MEMORY=512mb
# Optional: set a Redis password (empty = no auth)
REDIS_PASSWORD=

# ── Ports (override to avoid collisions) ──────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
LOGS_PORT=9999

# ── Worker tuning ─────────────────────────────────────────────────────────────
UVICORN_WORKERS=2
CELERY_CONCURRENCY=4

# ── Dozzle log UI (leave blank for no auth) ───────────────────────────────────
DOZZLE_USERNAME=
DOZZLE_PASSWORD=

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_THRESHOLD_SCORE=0.7
ENABLE_ADVERSARIAL_TESTING=true

# ── Frontend (for local dev without Docker) ───────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
